# ESP8266 Device Configuration
DEVICE_IP=192.168.1.100        # ESP8266 IP address (or smartlight.local)
DEVICE_PORT=80                  # ESP8266 HTTP port
DEVICE_TIMEOUT=10               # HTTP timeout in seconds

# Server Configuration
PORT=8000                       # MCP server port

# Development
MOCK_MODE=false                 # Set to "true" to run without real hardware
